[Unit]
Description=MiniMax Token Monitor
After=network.target

[Service]
Type=simple
User=kali
WorkingDirectory=%h/.openclaw/workspace/skills/minimax-token/scripts
ExecStart=/usr/bin/python3 %h/.openclaw/workspace/skills/minimax-token/scripts/minimax_token.py --monitor
Restart=always
RestartSec=10

# 日志 - 使用默认的 OpenClaw 日志目录
StandardOutput=append:%h/.openclaw/logs/token_monitor.log
StandardError=append:%h/.openclaw/logs/token_monitor.log

# 环境变量配置 (根据需要修改)
# Environment=MINIMAX_API_KEY=your_api_key
# Environment=TELEGRAM_BOT_TOKEN=your_bot_token
# Environment=TELEGRAM_CHAT_ID=your_chat_id
# Environment=OPENCLAW_LOG_DIR=%h/.openclaw/logs

[Install]
WantedBy=multi-user.target
